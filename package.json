{
  "name": "project-context",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "project-context": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/project-context",
    "check": "bun run typecheck && bun run lint && bun test",
    "format": "biome check --write .",
    "install:user": "bun run build && bun ./scripts/install-user.ts",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "chalk": "^5.6.2",
    "yaml": "^2.9.0",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "@types/yargs": "^17.0.35",
    "typescript": "^7.0.2"
  }
}
