{
  "name": "project-context",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "project-context": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/project-context",
    "check": "bun run typecheck && bun run lint && bun test",
    "format": "biome check --write .",
    "install:user": "bun run build && bun ./scripts/install-user.ts",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ajv": "^8.17.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
