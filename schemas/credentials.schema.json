{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-context.local/schemas/credentials.schema.json",
  "title": "project-context credential registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "credentials"],
  "properties": {
    "version": { "const": 1 },
    "credentials": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/alias" },
      "additionalProperties": { "$ref": "#/$defs/credential" }
    }
  },
  "$defs": {
    "alias": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/source" }
        }
      }
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "path"],
          "properties": {
            "source": { "const": "file" },
            "path": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "command"],
          "properties": {
            "source": { "const": "command" },
            "command": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "variable"],
          "properties": {
            "source": { "const": "environment" },
            "variable": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "service", "account"],
          "properties": {
            "source": { "const": "keychain" },
            "service": { "type": "string", "minLength": 1 },
            "account": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "value"],
          "properties": {
            "source": { "const": "literal" },
            "value": { "type": "string" }
          }
        }
      ]
    }
  }
}
